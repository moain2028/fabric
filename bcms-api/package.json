    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.1",
    "prom-client": "^15.0.0",
    "winston": "^3.11.0",
    "fabric-ca-client": "^2.2.19",
    "fabric-network": "^2.2.19",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
