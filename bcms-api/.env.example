# BCMS REST API Configuration (ABAC Version)
PORT=3000
LOG_LEVEL=info
CORS_ORIGIN=*

# Hyperledger Fabric Network
FABRIC_PATH=../test-network
CHANNEL_NAME=mychannel
CHAINCODE_NAME=basic

# Peer Endpoint (ABAC uses single org with role-based access)
PEER_ENDPOINT=localhost:7051

# ABAC Wallet Path (path to enrolled ABAC user identities)
WALLET_PATH=./src/fabric/wallet

# Access Control Model
ACCESS_CONTROL_MODEL=ABAC

# ABAC User Credentials (used by abacEnroll.js)
# admin-bcms — role=admin → InitLedger, RevokeCertificate
ADMIN_BCMS_SECRET=admin-bcms-pw
# issuer-bcms — role=issuer → IssueCertificate, VerifyCertificate
ISSUER_BCMS_SECRET=issuer-bcms-pw
# verifier-bcms — role=verifier → VerifyCertificate
VERIFIER_BCMS_SECRET=verifier-bcms-pw
